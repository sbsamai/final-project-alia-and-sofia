def setup_weather_database():
    conn = sqlite3.connect("weather_data.db")
    cursor = conn.cursor()
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS weather_data (
                   id INTEGER PRIMARY KEY AUTOINCREMENT,
                   city TEXT,
                   country TEXT,
                   temperature_f REAL,
                   feels_like_f REAL
                   humidity INTEGER,
                   wind_speed_mph REAL,
                   weather_description TEXT,
                   observation_time TEXT,
                   fetched_at TEXT)
                   """)
    conn.commit()
    return conn


